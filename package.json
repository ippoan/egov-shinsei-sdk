{
  "name": "@ippoan/egov-shinsei-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for e-Gov Electronic Application API (電子申請API v2)",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "LICENSE",
    "README.md",
    "docs"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "e-gov",
    "egov",
    "electronic-application",
    "shinsei",
    "japan",
    "government-api",
    "digital-agency"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "collect-ids": "npx tsx scripts/collect-arrive-ids.ts",
    "package-evidence": "npx tsx scripts/package-evidence.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "[ \"$CI\" = 'true' ] || { echo 'ERROR: Direct npm publish is not allowed. Use git tag.'; exit 1; }"
  },
  "devDependencies": {
    "@types/node-forge": "^1.3.14",
    "@vitest/coverage-v8": "^3",
    "dotenv": "^17.4.2",
    "msw": "^2",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "linkedom": "^0.18.12",
    "node-forge": "^1.4.0"
  }
}
